{%- comment -%} ================== REVIEWS ================== {%- endcomment -%}
<section class="section-pad bg-slate-50" x-data="{ page: 0 }">
  <div class="container-x">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <span class="chip mb-3">Reviews</span>
      <h2 class="text-3xl md:text-5xl font-black tracking-tight">Mensen lijken ons <span class="gradient-text">leuk te vinden</span></h2>
      <p class="mt-4 text-slate-600">Echte ervaringen van echte klanten</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {% render 'review-card', name: 'Sanne de Vries', initial: 'S', product: 'iPhone 14', text: 'Mijn iPhone 14 ziet eruit als nieuw en werkt perfect. De besparing was enorm en de levering ging razendsnel.', group: 0 %}
      {% render 'review-card', name: 'Mark Janssen', initial: 'M', product: 'Samsung Galaxy S23', text: 'Snelle levering, goed verpakt. De garantie gaf me het vertrouwen om refurbished te proberen.', group: 0 %}
      {% render 'review-card', name: 'Lisa Bakker', initial: 'L', product: 'iPhone 15 Pro', text: 'Supergoed proces. Ik verkocht mijn oude telefoon en kreeg direct mijn nieuwe. Alles binnen een week geregeld.', group: 0 %}
      {% render 'review-card', name: 'Tom van Dijk', initial: 'T', product: 'iPhone 16 Pro', text: 'Prachtige kwaliteit, geen krasje te bekennen. De batterij is top en alles werkt als vanouds.', group: 1 %}
      {% render 'review-card', name: 'Emma Visser', initial: 'E', product: 'iPhone 13', text: 'Ik was sceptisch over refurbished maar Pixel heeft me overtuigd. Geweldige klantenservice ook!', group: 1 %}
      {% render 'review-card', name: 'Daan Smit', initial: 'D', product: 'Samsung S24', text: 'Beste keuze ooit. Bespaarde honderden euro en nog goed voor de planeet ook.', group: 1 %}
      {% render 'review-card', name: 'Fleur Hendriks', initial: 'F', product: 'iPhone 15 Plus', text: 'Communicatie was uitstekend track en trace werkt perfect. Mijn telefoon kwam in mint conditie.', group: 2 %}
      {% render 'review-card', name: 'Julian Bos', initial: 'J', product: 'Galaxy S22 Ultra', text: 'Van bestelling tot ontvangst alles gladjes verlopen. Absoluut een aanrader voor iedereen.', group: 2 %}
      {% render 'review-card', name: 'Nina Peters', initial: 'N', product: 'Galaxy S25 Ultra', text: 'Super blij met mijn aankoop. Snelle levering en de telefoon werkt perfect!', group: 2 %}
    </div>

    <div class="mt-10 flex items-center justify-center gap-3">
      <button type="button" @click="page = (page - 1 + 3) % 3" class="w-12 h-12 rounded-full bg-white border border-slate-200 flex items-center justify-center hover:border-brand-500 hover:text-brand-700 hover:shadow-md transition" aria-label="Vorige reviews">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <div class="flex items-center gap-2 px-4">
        <template x-for="i in [0,1,2]" :key="i">
          <button type="button" @click="page = i" :class="i === page ? 'w-8 bg-gradient-to-r from-brand-600 to-cyan-600' : 'w-2 bg-slate-300 hover:bg-slate-400'" class="h-2 rounded-full transition-all"></button>
        </template>
      </div>
      <button type="button" @click="page = (page + 1) % 3" class="w-12 h-12 rounded-full bg-white border border-slate-200 flex items-center justify-center hover:border-brand-500 hover:text-brand-700 hover:shadow-md transition" aria-label="Volgende reviews">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>
</section>

