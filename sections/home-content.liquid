{%- comment -%} DIAGNOSTIC — remove after fix {%- endcomment -%}
<div style="background:#fef3c7;padding:10px;font-family:monospace;font-size:12px;border-bottom:2px solid #f59e0b">
  pp_json length: {{ pp_json | size }}
  | pixel_products size: {{ pixel_products | size }}
  | iphones size: {{ iphones | size }}
  | samsungs size: {{ samsungs | size }}
  | pp_json first 80: {{ pp_json | truncate: 80 | escape }}
  | pixel_products first slug: {{ pixel_products[0].slug | default: 'NIL' }}
</div>

