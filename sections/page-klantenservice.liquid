<section class="bg-gradient-to-br from-brand-50 to-cyan-50 border-b border-slate-200">
  <div class="container-x py-16 text-center">
    <span class="chip mb-3">Klantenservice</span>
    <h1 class="text-4xl md:text-6xl font-black tracking-tight">Hoe kunnen we <span class="gradient-text">helpen?</span></h1>
    <div class="mt-8 max-w-xl mx-auto relative">
      <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="search" placeholder="Zoek in onze helpcentrum..." class="w-full pl-14 pr-5 py-4 rounded-full bg-white border border-slate-200 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/20 shadow-sm">
    </div>
  </div>
</section>

<section class="container-x py-16" x-data="{ active: 'orders', open: null }">
  <div class="grid lg:grid-cols-4 gap-8">
    <aside class="lg:col-span-1">
      <div class="card p-4 sticky top-24">
        <button type="button" @click="active = 'orders'; open = null" :class="active === 'orders' ? 'bg-brand-50 text-brand-700' : 'hover:bg-slate-50 text-slate-700'" class="w-full flex items-center gap-3 px-4 py-3 rounded-2xl text-left transition">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          <span class="font-medium">Bestellingen</span>
        </button>
        <button type="button" @click="active = 'shipping'; open = null" :class="active === 'shipping' ? 'bg-brand-50 text-brand-700' : 'hover:bg-slate-50 text-slate-700'" class="w-full flex items-center gap-3 px-4 py-3 rounded-2xl text-left transition">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/></svg>
          <span class="font-medium">Verzending</span>
        </button>
        <button type="button" @click="active = 'warranty'; open = null" :class="active === 'warranty' ? 'bg-brand-50 text-brand-700' : 'hover:bg-slate-50 text-slate-700'" class="w-full flex items-center gap-3 px-4 py-3 rounded-2xl text-left transition">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span class="font-medium">Garantie</span>
        </button>
        <button type="button" @click="active = 'quality'; open = null" :class="active === 'quality' ? 'bg-brand-50 text-brand-700' : 'hover:bg-slate-50 text-slate-700'" class="w-full flex items-center gap-3 px-4 py-3 rounded-2xl text-left transition">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span class="font-medium">Kwaliteit</span>
        </button>
        <button type="button" @click="active = 'payment'; open = null" :class="active === 'payment' ? 'bg-brand-50 text-brand-700' : 'hover:bg-slate-50 text-slate-700'" class="w-full flex items-center gap-3 px-4 py-3 rounded-2xl text-left transition">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          <span class="font-medium">Betalen</span>
        </button>
      </div>
    </aside>

    <div class="lg:col-span-3">
      {%- comment -%} Bestellingen {%- endcomment -%}
      <div x-show="active === 'orders'">
        <h2 class="text-3xl font-black mb-6">Bestellingen</h2>
        <div class="space-y-3">
          {% render 'faq-item', q: 'Hoe plaats ik een bestelling?', a: 'Kies een telefoon en klik op Bestel via WhatsApp om persoonlijk afgehandeld te worden.', k: 'orders-1' %}
          {% render 'faq-item', q: 'Kan ik mijn bestelling wijzigen?', a: 'Ja, neem binnen 1 uur na je bestelling contact op via WhatsApp.', k: 'orders-2' %}
          {% render 'faq-item', q: 'Welke betaalmethoden accepteren jullie?', a: 'We accepteren iDEAL, Bancontact en Apple Pay. Alle betalingen zijn direct.', k: 'orders-3' %}
        </div>
      </div>

      {%- comment -%} Verzending {%- endcomment -%}
      <div x-show="active === 'shipping'">
        <h2 class="text-3xl font-black mb-6">Verzending</h2>
        <div class="space-y-3">
          {% render 'faq-item', q: 'Hoe snel wordt mijn bestelling geleverd?', a: 'Bestellingen voor 22:00 uur worden de volgende werkdag geleverd via PostNL of DHL.', k: 'ship-1' %}
          {% render 'faq-item', q: 'Is verzending gratis?', a: 'Ja, alle bestellingen binnen Nederland en Belgi&euml; worden gratis en CO2-neutraal verzonden.', k: 'ship-2' %}
          {% render 'faq-item', q: 'Kan ik mijn bestelling volgen?', a: 'Je ontvangt een track en trace link zodra je pakket onderweg is.', k: 'ship-3' %}
        </div>
      </div>

      {%- comment -%} Garantie {%- endcomment -%}
      <div x-show="active === 'warranty'">
        <h2 class="text-3xl font-black mb-6">Garantie</h2>
        <div class="space-y-3">
          {% render 'faq-item', q: 'Hoe lang is de garantie?', a: 'Elke refurbished telefoon komt met 6 maanden garantie op alle onderdelen en functies.', k: 'warr-1' %}
          {% render 'faq-item', q: 'Wat valt er onder de garantie?', a: 'Alle fabricagefouten en interne defecten. Schade door vallen of vocht valt er niet onder.', k: 'warr-2' %}
          {% render 'faq-item', q: 'Hoe claim ik mijn garantie?', a: 'Neem contact op via WhatsApp met je bestelnummer en een omschrijving. We reageren binnen 24 uur.', k: 'warr-3' %}
        </div>
      </div>

      {%- comment -%} Kwaliteit {%- endcomment -%}
      <div x-show="active === 'quality'">
        <h2 class="text-3xl font-black mb-6">Kwaliteit</h2>
        <div class="space-y-3">
          {% render 'faq-item', q: 'Wat is de 72-punten check?', a: 'Een uitgebreide inspectie op 72 onderdelen: scherm, batterij, camera, knoppen, poorten en alle software-functies.', k: 'qual-1' %}
          {% render 'faq-item', q: 'Hoe goed is de batterij?', a: 'We garanderen minimaal 85 procent batterijcapaciteit op elk toestel.', k: 'qual-2' %}
        </div>
      </div>

      {%- comment -%} Betalen {%- endcomment -%}
      <div x-show="active === 'payment'">
        <h2 class="text-3xl font-black mb-6">Betalen</h2>
        <div class="space-y-3">
          {% render 'faq-item', q: 'Welke betaalmethoden zijn er?', a: 'iDEAL, Bancontact of Apple Pay.', k: 'pay-1' %}
          {% render 'faq-item', q: 'Kan ik achteraf betalen?', a: 'Nee, we werken uitsluitend met directe betaalmethoden.', k: 'pay-2' %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Klantenservice content", "settings": [], "presets": [{ "name": "Klantenservice content" }] }
{% endschema %}
