{% render 'pixel-products' %}
{%- assign wa_number = '31624978746' -%}

<!-- All products rendered, only the matching one is shown via JS based on ?p= param -->
<div x-data="{
  slug: (new URLSearchParams(window.location.search)).get('p') || 'iphone-15-pro-natural',
  init() {
    // Set active product class
    this.$nextTick(() => {
      document.querySelectorAll('[data-product-page]').forEach(el => {
        el.style.display = el.dataset.productPage === this.slug ? 'block' : 'none';
      });
    });
  }
}">

{% for product in pixel_products %}
  {%- assign discount = product.original | minus: product.price | times: 100 | divided_by: product.original -%}
  {%- assign saving = product.original | minus: product.price -%}
  {%- assign related = pixel_products | where: 'brand', product.brand -%}
  {%- assign wa_msg = 'Hoi Pixel! Ik wil graag de ' | append: product.name | append: ' (' | append: product.storage | append: ' · ' | append: product.color | append: ') bestellen voor €' | append: product.price | append: '. Kunnen jullie mij helpen?' -%}
  {%- assign wa_href = 'https://wa.me/' | append: wa_number | append: '?text=' | append: wa_msg | url_encode -%}
  {%- capture color_css -%}{% render 'color-swatch', name: product.color %}{%- endcapture -%}

  <div data-product-page="{{ product.slug }}" style="display: none;">
    <!-- Breadcrumb -->
    <div class="container-x pt-6">
      <div class="flex items-center gap-2 text-xs text-slate-500">
        <a href="/" class="hover:text-brand-700">Home</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        <a href="/pages/telefoons" class="hover:text-brand-700">Telefoons</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="text-slate-900">{{ product.name }}</span>
      </div>
    </div>

    <section class="container-x py-10" x-data="{ active: 0 }">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Gallery -->
        <div>
          <div class="card aspect-square overflow-hidden bg-gradient-to-br from-slate-50 to-slate-100 relative">
            {% for i in (1..6) %}
              {%- assign idx = forloop.index0 -%}
              {%- assign n = i | prepend: '0' | slice: -2, 2 -%}
              {%- assign src = product.slug | prepend: 'p-' | append: '-' | append: n | append: '.jpg' | asset_url -%}
              <img x-show="active === {{ idx }}" src="{{ src }}" alt="{{ product.name }}" class="w-full h-full object-contain p-8 {% if product.sold %}grayscale opacity-70{% endif %}">
            {% endfor %}

            {% unless product.sold %}
              {% if discount > 0 %}
                <span class="absolute top-4 right-4 text-sm font-bold px-3 py-1.5 rounded-full bg-rose-600 text-white">-{{ discount }}%</span>
              {% endif %}
            {% endunless %}

            {% if product.sold %}
              <div class="absolute inset-0 bg-slate-900/15 pointer-events-none"></div>
              <div class="absolute inset-0 overflow-hidden pointer-events-none">
                <div class="absolute top-12 -right-20 w-[180%] rotate-[-20deg] bg-gradient-to-r from-rose-600 to-red-600 text-white text-center py-3 shadow-xl ring-1 ring-white/30">
                  <span class="text-xl md:text-2xl font-black tracking-[0.2em] uppercase drop-shadow">Verkocht</span>
                </div>
              </div>
            {% endif %}
          </div>

          <div class="mt-4 grid grid-cols-6 gap-2 sm:gap-3">
            {% for i in (1..6) %}
              {%- assign idx = forloop.index0 -%}
              {%- assign n = i | prepend: '0' | slice: -2, 2 -%}
              {%- assign src = product.slug | prepend: 'p-' | append: '-' | append: n | append: '.jpg' | asset_url -%}
              <button type="button" @click="active = {{ idx }}" :class="active === {{ idx }} ? 'border-brand-500' : 'border-transparent hover:border-slate-300'" class="aspect-square rounded-2xl overflow-hidden border-2 transition bg-slate-50">
                <img src="{{ src }}" alt="" class="w-full h-full object-contain p-2">
              </button>
            {% endfor %}
          </div>
        </div>

        <!-- Info -->
        <div>
          <div class="flex items-center gap-3 text-sm mb-3">
            <span class="text-slate-500">{{ product.brand }}</span>
            <span class="text-slate-300">·</span>
            <div class="flex items-center gap-1">
              <svg class="w-4 h-4 fill-amber-400 text-amber-400" viewBox="0 0 24 24"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              <span class="font-semibold">{{ product.rating }}</span>
              <span class="text-slate-500">({{ product.reviews }} reviews)</span>
            </div>
          </div>
          <h1 class="text-3xl md:text-4xl font-black tracking-tight">{{ product.name }}</h1>
          <p class="mt-3 text-slate-600">{{ product.description }}</p>

          <div class="mt-6 flex items-end gap-3">
            <div class="text-4xl font-black gradient-text">€{{ product.price }}</div>
            <div class="text-slate-400 line-through mb-1">€{{ product.original }}</div>
            <span class="ml-2 mb-1 text-sm font-semibold text-emerald-700 bg-emerald-50 border border-emerald-100 px-2 py-1 rounded-full">Bespaar €{{ saving }}</span>
          </div>
          <p class="mt-1 text-xs text-slate-500">Bestel direct via WhatsApp · Persoonlijke service</p>

          <div class="mt-6 flex items-center gap-2 text-sm">
            <svg class="w-4 h-4 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="6" width="18" height="12" rx="2"/></svg>
            <span class="font-medium">{{ product.battery }}% batterij</span>
            <span class="text-slate-400">·</span>
            <span class="text-slate-600">Getest en goedgekeurd</span>
          </div>

          <div class="mt-8 flex flex-wrap gap-2">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-slate-200 bg-slate-50 text-sm font-medium">
              <span class="w-3 h-3 rounded-full border border-slate-300" style="background: {{ color_css | strip }};"></span>
              {{ product.color }}
            </div>
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-slate-200 bg-slate-50 text-sm font-medium">{{ product.storage }}</div>
          </div>
          <p class="mt-2 text-xs text-slate-500">Uniek toestel — de foto's zijn van deze specifieke telefoon.</p>

          {% if product.sold %}
            <div class="mt-8 p-5 rounded-2xl bg-slate-100 border border-slate-200 text-center">
              <div class="text-sm font-semibold uppercase tracking-wide text-slate-500 mb-1">Niet op voorraad</div>
              <div class="text-lg font-bold text-slate-900">Dit toestel is verkocht</div>
            </div>
          {% else %}
            <div class="mt-8">
              <a href="{{ wa_href }}" target="_blank" rel="noopener noreferrer" class="btn-wa w-full">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                Bestel via WhatsApp
              </a>
            </div>
          {% endif %}

          <div class="mt-8 grid grid-cols-3 gap-3">
            <div class="flex flex-col items-center text-center p-4 rounded-2xl bg-slate-50">
              <svg class="w-5 h-5 text-brand-600 mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <span class="text-xs font-medium">6 maanden garantie</span>
            </div>
            <div class="flex flex-col items-center text-center p-4 rounded-2xl bg-slate-50">
              <svg class="w-5 h-5 text-brand-600 mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <span class="text-xs font-medium">Gratis verzending</span>
            </div>
            <div class="flex flex-col items-center text-center p-4 rounded-2xl bg-slate-50">
              <svg class="w-5 h-5 text-brand-600 mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span class="text-xs font-medium">72-punten check</span>
            </div>
          </div>
        </div>
      </div>

      <!-- What you get -->
      <div class="mt-20">
        <h2 class="text-2xl md:text-3xl font-black tracking-tight mb-8">Wat je krijgt</h2>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="card p-6">
            <div class="w-10 h-10 rounded-xl bg-brand-100 text-brand-700 flex items-center justify-center mb-4">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <h3 class="font-bold">72-punten inspectie</h3>
            <p class="text-sm text-slate-600 mt-1">Elke telefoon wordt grondig getest op alle functies</p>
          </div>
          <div class="card p-6">
            <div class="w-10 h-10 rounded-xl bg-brand-100 text-brand-700 flex items-center justify-center mb-4">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            </div>
            <h3 class="font-bold">Nieuwe batterij</h3>
            <p class="text-sm text-slate-600 mt-1">Batterijen onder 85% worden altijd vervangen</p>
          </div>
          <div class="card p-6">
            <div class="w-10 h-10 rounded-xl bg-brand-100 text-brand-700 flex items-center justify-center mb-4">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3 class="font-bold">Originele onderdelen</h3>
            <p class="text-sm text-slate-600 mt-1">We gebruiken alleen premium vervangende onderdelen</p>
          </div>
        </div>
      </div>

      <!-- Related (max 4 from same brand, excluding current) -->
      {%- assign rel_count = 0 -%}
      <div class="mt-20">
        <h2 class="text-2xl md:text-3xl font-black tracking-tight mb-8">Ook interessant</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
          {% for r in related %}
            {%- if r.slug != product.slug and rel_count < 4 -%}
              {%- assign rel_count = rel_count | plus: 1 -%}
              {% render 'product-card', product: r %}
            {%- endif -%}
          {% endfor %}
        </div>
      </div>
    </section>
  </div>
{% endfor %}

</div>

{% schema %}
{
  "name": "Telefoon detail",
  "settings": [],
  "presets": [{ "name": "Telefoon detail" }]
}
{% endschema %}
