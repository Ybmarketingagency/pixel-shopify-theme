<section class="relative overflow-hidden bg-slate-950 text-white">
  <div class="absolute inset-0 -z-10 opacity-40">
    <div class="absolute top-1/2 left-1/4 w-96 h-96 rounded-full bg-brand-600 blur-3xl"></div>
    <div class="absolute top-1/3 right-1/4 w-96 h-96 rounded-full bg-cyan-600 blur-3xl"></div>
  </div>
  <div class="container-x py-16 md:py-20">
    <div class="flex items-center gap-2 text-xs text-slate-400 mb-4">
      <a href="/" class="hover:text-white">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      <span class="text-white">Telefoons</span>
    </div>
    <h1 class="text-4xl md:text-6xl font-black tracking-tight">Alle <span class="gradient-text">telefoons</span></h1>
    <p class="mt-4 text-slate-300 max-w-xl">Getest, gegarandeerd en klaar om te gebruiken. Kies uit 20 refurbished modellen met 6 maanden garantie.</p>
  </div>
</section>

<section class="container-x py-10" x-data="{
  brands: [],
  init() {
    const params = new URLSearchParams(window.location.search);
    const b = params.get('brand');
    if (b) this.brands = [b];
    this.applyFilters();
    this.$watch('brands', () => this.applyFilters());
  },
  toggleBrand(b) { this.brands = this.brands.includes(b) ? this.brands.filter(x => x !== b) : [...this.brands, b]; },
  applyFilters() {
    document.querySelectorAll('[data-grid-item]').forEach(el => {
      const b = el.dataset.brand;
      el.style.display = (this.brands.length === 0 || this.brands.includes(b)) ? '' : 'none';
    });
  }
}">
  <div class="flex flex-col lg:flex-row gap-8">
    <aside class="lg:w-72 flex-shrink-0">
      <div class="card p-6 sticky top-24">
        <h3 class="font-bold text-lg mb-4">Filters</h3>
        <div class="mb-6">
          <h4 class="font-semibold text-sm mb-3">Merk</h4>
          <div class="space-y-2">
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" @change="toggleBrand('Apple')" :checked="brands.includes('Apple')" class="w-4 h-4 accent-brand-600 rounded">
              <span class="text-sm text-slate-700">Apple</span>
              <span class="ml-auto text-xs text-slate-400">14</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" @change="toggleBrand('Samsung')" :checked="brands.includes('Samsung')" class="w-4 h-4 accent-brand-600 rounded">
              <span class="text-sm text-slate-700">Samsung</span>
              <span class="ml-auto text-xs text-slate-400">6</span>
            </label>
          </div>
        </div>
        <button type="button" @click="brands = []" class="w-full text-sm font-medium text-brand-700 hover:underline">Filters wissen</button>
      </div>
    </aside>

    <div class="flex-1">
      <div class="text-sm text-slate-600 mb-6"><strong class="text-slate-900">20</strong> telefoons beschikbaar</div>

      {%- comment -%} Render all 20 cards in a grid. Each card wraps in snap-start (slider style) — override to full width for grid layout. {%- endcomment -%}
      <div class="grid grid-cols-2 md:grid-cols-3 gap-5">
        <div data-grid-item data-brand="Apple">{% render 'product-card', slug: 'iphone-13', name: 'iPhone 13', brand: 'Apple', storage: '128GB', color: 'Blauw', battery: 92, price: 249, original: 729, rating: 4.7, sold: false %}</div>
        <div data-grid-item data-brand="Apple">{% render 'product-card', slug: 'iphone-13-pro', name: 'iPhone 13 Pro', brand: 'Apple', storage: '128GB', color: 'Blauw', battery: 90, price: 289, original: 1159, rating: 4.8, sold: true %}</div>
        <div data-grid-item data-brand="Apple">{% render 'product-card', slug: 'iphone-13-pro-max', name: 'iPhone 13 Pro Max', brand: 'Apple', storage: '256GB', color: 'Goud', battery: 91, price: 379, original: 1389, rating: 4.9, sold: true %}</div>
        <div data-grid-item data-brand="Apple">{% render 'product-card', slug: 'iphone-14-pro', name: 'iPhone 14 Pro', brand: 'Apple', storage: '128GB', color: 'Zwart', battery: 93, price: 399, original: 1329, rating: 4.9, sold: false %}</div>
        <div data-grid-item data-brand="Apple">{% render 'product-card', slug: 'iphone-14-pro-max', name: 'iPhone 14 Pro Max', brand: 'Apple', storage: '256GB', color: 'Zwart', battery: 94, price: 489, original: 1629, rating: 4.9, sold: false %}</div>
        <div data-grid-item data-brand="Apple">{% render 'product-card', slug: 'iphone-15', name: 'iPhone 15', brand: 'Apple', storage: '128GB', color: 'Zwart', battery: 96, price: 339, original: 969, rating: 4.8, sold: true %}</div>
        <div data-grid-item data-brand="Apple">{% render 'product-card', slug: 'iphone-15-plus', name: 'iPhone 15 Plus', brand: 'Apple', storage: '128GB', color: 'Roze', battery: 95, price: 389, original: 1149, rating: 4.8, sold: true %}</div>
        <div data-grid-item data-brand="Apple">{% render 'product-card', slug: 'iphone-15-pro-black', name: 'iPhone 15 Pro', brand: 'Apple', storage: '128GB', color: 'Black Titanium', battery: 97, price: 469, original: 1229, rating: 4.9, sold: false %}</div>
        <div data-grid-item data-brand="Apple">{% render 'product-card', slug: 'iphone-15-pro-white', name: 'iPhone 15 Pro', brand: 'Apple', storage: '128GB', color: 'White Titanium', battery: 97, price: 469, original: 1229, rating: 4.9, sold: false %}</div>
        <div data-grid-item data-brand="Apple">{% render 'product-card', slug: 'iphone-15-pro-natural', name: 'iPhone 15 Pro', brand: 'Apple', storage: '128GB', color: 'Natural Titanium', battery: 97, price: 519, original: 1229, rating: 4.9, sold: false %}</div>
        <div data-grid-item data-brand="Apple">{% render 'product-card', slug: 'iphone-15-pro-max', name: 'iPhone 15 Pro Max', brand: 'Apple', storage: '256GB', color: 'Blue Titanium', battery: 96, price: 649, original: 1449, rating: 5.0, sold: true %}</div>
        <div data-grid-item data-brand="Apple">{% render 'product-card', slug: 'iphone-16', name: 'iPhone 16', brand: 'Apple', storage: '256GB', color: 'Zwart', battery: 98, price: 499, original: 969, rating: 4.9, sold: false %}</div>
        <div data-grid-item data-brand="Apple">{% render 'product-card', slug: 'iphone-16-pro', name: 'iPhone 16 Pro', brand: 'Apple', storage: '128GB', color: 'Zwart', battery: 99, price: 599, original: 1229, rating: 5.0, sold: false %}</div>
        <div data-grid-item data-brand="Apple">{% render 'product-card', slug: 'iphone-16-pro-max', name: 'iPhone 16 Pro Max', brand: 'Apple', storage: '256GB', color: 'Desert Titanium', battery: 99, price: 699, original: 1479, rating: 5.0, sold: true %}</div>
        <div data-grid-item data-brand="Samsung">{% render 'product-card', slug: 'samsung-s22-ultra', name: 'Samsung Galaxy S22 Ultra', brand: 'Samsung', storage: '256GB', color: 'Groen', battery: 89, price: 349, original: 1249, rating: 4.7, sold: true %}</div>
        <div data-grid-item data-brand="Samsung">{% render 'product-card', slug: 'samsung-s23-ultra', name: 'Samsung Galaxy S23 Ultra', brand: 'Samsung', storage: '256GB', color: 'Zwart', battery: 93, price: 449, original: 1399, rating: 4.8, sold: true %}</div>
        <div data-grid-item data-brand="Samsung">{% render 'product-card', slug: 'samsung-s24-grey', name: 'Samsung Galaxy S24', brand: 'Samsung', storage: '128GB', color: 'Grijs', battery: 95, price: 449, original: 899, rating: 4.7, sold: true %}</div>
        <div data-grid-item data-brand="Samsung">{% render 'product-card', slug: 'samsung-s24-black', name: 'Samsung Galaxy S24', brand: 'Samsung', storage: '128GB', color: 'Zwart', battery: 95, price: 449, original: 899, rating: 4.7, sold: true %}</div>
        <div data-grid-item data-brand="Samsung">{% render 'product-card', slug: 'samsung-s25-ultra-grey', name: 'Samsung Galaxy S25 Ultra', brand: 'Samsung', storage: '256GB', color: 'Titanium Grijs', battery: 98, price: 849, original: 1499, rating: 5.0, sold: true %}</div>
        <div data-grid-item data-brand="Samsung">{% render 'product-card', slug: 'samsung-s25-ultra-white', name: 'Samsung Galaxy S25 Ultra', brand: 'Samsung', storage: '256GB', color: 'Titanium Wit', battery: 98, price: 849, original: 1499, rating: 5.0, sold: true %}</div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Cards in grid should be full-width of their grid cell (override the slider's 70% w- class) */
  [data-grid-item] > div { width: 100% !important; }
</style>

{% schema %}
{ "name": "Telefoons listing", "settings": [], "presets": [{ "name": "Telefoons listing" }] }
{% endschema %}
