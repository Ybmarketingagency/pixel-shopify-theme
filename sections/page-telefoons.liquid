{%- capture pp_json -%}{% render 'pixel-products' %}{%- endcapture -%}
{%- assign pixel_products = pp_json | parse_json -%}

<section class="relative overflow-hidden bg-slate-950 text-white">
  <div class="absolute inset-0 -z-10 opacity-40">
    <div class="absolute top-1/2 left-1/4 w-96 h-96 rounded-full bg-brand-600 blur-3xl"></div>
    <div class="absolute top-1/3 right-1/4 w-96 h-96 rounded-full bg-cyan-600 blur-3xl"></div>
  </div>
  <div class="container-x py-16 md:py-20">
    <div class="flex items-center gap-2 text-xs text-slate-400 mb-4">
      <a href="/" class="hover:text-white">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      <span class="text-white">Telefoons</span>
    </div>
    <h1 class="text-4xl md:text-6xl font-black tracking-tight">Alle <span class="gradient-text">telefoons</span></h1>
    <p class="mt-4 text-slate-300 max-w-xl">Getest, gegarandeerd en klaar om te gebruiken. Kies uit {{ pixel_products | size }}+ refurbished modellen met 6 maanden garantie.</p>
  </div>
</section>

<section class="container-x py-10" x-data="{
  brands: [],
  maxPrice: 1500,
  open: false,
  toggleBrand(b) { this.brands = this.brands.includes(b) ? this.brands.filter(x => x !== b) : [...this.brands, b]; },
  init() {
    const params = new URLSearchParams(window.location.search);
    const b = params.get('brand');
    if (b) this.brands = [b];
  }
}">
  <div class="flex flex-col lg:flex-row gap-8">
    <aside class="lg:w-72 flex-shrink-0" :class="open ? 'block' : 'hidden lg:block'">
      <div class="card p-6 sticky top-24">
        <h3 class="font-bold text-lg mb-4">Filters</h3>

        <div class="mb-6">
          <h4 class="font-semibold text-sm mb-3">Merk</h4>
          <div class="space-y-2">
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" @change="toggleBrand('Apple')" :checked="brands.includes('Apple')" class="w-4 h-4 accent-brand-600 rounded">
              <span class="text-sm text-slate-700">Apple</span>
              <span class="ml-auto text-xs text-slate-400">{{ pixel_products | where: 'brand', 'Apple' | size }}</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" @change="toggleBrand('Samsung')" :checked="brands.includes('Samsung')" class="w-4 h-4 accent-brand-600 rounded">
              <span class="text-sm text-slate-700">Samsung</span>
              <span class="ml-auto text-xs text-slate-400">{{ pixel_products | where: 'brand', 'Samsung' | size }}</span>
            </label>
          </div>
        </div>

        <div>
          <h4 class="font-semibold text-sm mb-3">Max prijs: &euro;<span x-text="maxPrice"></span></h4>
          <input type="range" min="200" max="1500" step="50" x-model.number="maxPrice" class="w-full accent-brand-600">
          <div class="flex justify-between text-xs text-slate-400 mt-1">
            <span>&euro;200</span><span>&euro;1500</span>
          </div>
        </div>

        <button type="button" @click="brands = []; maxPrice = 1500;" class="mt-6 w-full text-sm font-medium text-brand-700 hover:underline">Filters wissen</button>
      </div>
    </aside>

    <div class="flex-1">
      <div class="flex items-center justify-between mb-6 gap-4">
        <div class="text-sm text-slate-600">
          <strong class="text-slate-900">{{ pixel_products | size }}</strong> telefoons beschikbaar
        </div>
        <button type="button" @click="open = !open" class="lg:hidden btn-outline" style="padding: .5rem 1rem;">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/></svg>
          Filters
        </button>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-5">
        {% for p in pixel_products %}
          <div x-show="(brands.length === 0 || brands.includes('{{ p.brand }}')) && {{ p.price }} <= maxPrice">
            {% render 'product-card', product: p %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Telefoons listing", "settings": [], "presets": [{ "name": "Telefoons listing" }] }
{% endschema %}
