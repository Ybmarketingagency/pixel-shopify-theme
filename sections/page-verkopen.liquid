{%- assign wa_number = '31624978746' -%}
{%- assign wa_general = 'https://wa.me/' | append: wa_number | append: '?text=Hoi%20Pixel!%20Ik%20wil%20mijn%20telefoon%20verkopen.%20Kunnen%20jullie%20mij%20een%20bod%20doen%3F' -%}
{%- assign wa_tradein = 'https://wa.me/' | append: wa_number | append: '?text=Hoi%20Pixel!%20Ik%20wil%20mijn%20telefoon%20inruilen%20voor%20een%20ander%20toestel.%20Kunnen%20jullie%20mij%20een%20bod%20doen%3F' -%}
{%- assign wa_direct = 'https://wa.me/' | append: wa_number | append: '?text=Hoi%20Pixel!%20Ik%20wil%20mijn%20telefoon%20verkopen%20(zonder%20inruil).%20Kunnen%20jullie%20mij%20een%20bod%20doen%3F' -%}

<section class="relative overflow-hidden bg-gradient-to-br from-brand-50 via-white to-emerald-50 border-b border-slate-200">
  <div class="absolute inset-0 -z-10 opacity-60">
    <div class="absolute -top-20 right-10 w-96 h-96 rounded-full bg-emerald-200/40 blur-3xl"></div>
    <div class="absolute bottom-0 -left-10 w-96 h-96 rounded-full bg-brand-200/40 blur-3xl"></div>
  </div>
  <div class="container-x py-16 md:py-20 text-center">
    <span class="chip mb-3">Verkopen via WhatsApp</span>
    <h1 class="text-4xl md:text-6xl font-black tracking-tight">Verkoop je <span class="gradient-text">telefoon</span></h1>
    <p class="mt-4 text-slate-600 max-w-xl mx-auto text-base md:text-lg">Geen calculators, geen omwegen. Stuur ons een berichtje op WhatsApp en we doen je een eerlijk bod — vaak binnen enkele minuten.</p>

    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href="{{ wa_general }}" target="_blank" rel="noopener noreferrer" class="btn-wa" style="padding: 1rem 2rem; font-size: 1.125rem;">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
        Chat op WhatsApp
      </a>
      <a href="tel:+31624978746" class="btn-outline">Of bel ons</a>
    </div>
    <p class="mt-4 text-xs text-slate-500">+31 6 24978746 · Ma-Za bereikbaar</p>
  </div>
</section>

<!-- Two options: trade-in vs direct -->
<section class="section-pad">
  <div class="container-x">
    <div class="text-center max-w-2xl mx-auto mb-10">
      <span class="chip mb-3">Twee manieren</span>
      <h2 class="text-3xl md:text-5xl font-black tracking-tight">Inruilen of <span class="gradient-text">direct verkopen</span></h2>
      <p class="mt-4 text-slate-600">Wil je een nieuw toestel bij ons? Ruil 'm in voor extra korting. Of verkoop je telefoon direct — zonder iets terug te kopen. Beide kan.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <a href="{{ wa_tradein }}" target="_blank" rel="noopener noreferrer" class="card p-8 relative overflow-hidden group hover:-translate-y-1 transition">
        <div class="absolute -top-8 -right-8 w-40 h-40 rounded-full bg-gradient-to-br from-brand-200/50 to-cyan-200/50 blur-2xl"></div>
        <div class="relative">
          <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-brand-500 to-cyan-500 text-white flex items-center justify-center mb-4 shadow-lg shadow-brand-600/30">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
          </div>
          <h3 class="text-2xl font-black">Inruilen</h3>
          <p class="mt-2 text-slate-600">Koop een nieuw toestel bij ons en ruil je oude in. Je krijgt het inruilbedrag direct van de aankoopprijs afgetrokken.</p>
          <ul class="mt-4 space-y-2 text-sm text-slate-700">
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Extra korting op je nieuwe telefoon</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Alles in één transactie</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Duurzaam — geen toestel in de la</li>
          </ul>
          <div class="mt-6 inline-flex items-center gap-2 text-brand-700 font-semibold">Start inruil via WhatsApp →</div>
        </div>
      </a>

      <a href="{{ wa_direct }}" target="_blank" rel="noopener noreferrer" class="card p-8 relative overflow-hidden group hover:-translate-y-1 transition">
        <div class="absolute -top-8 -right-8 w-40 h-40 rounded-full bg-gradient-to-br from-emerald-200/50 to-teal-200/50 blur-2xl"></div>
        <div class="relative">
          <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-emerald-500 to-emerald-600 text-white flex items-center justify-center mb-4 shadow-lg shadow-emerald-600/30">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          </div>
          <h3 class="text-2xl font-black">Direct verkopen</h3>
          <p class="mt-2 text-slate-600">Geen nieuwe telefoon nodig? We kopen 'm ook gewoon van je over. Je krijgt het bedrag netjes overgemaakt na de deal.</p>
          <ul class="mt-4 space-y-2 text-sm text-slate-700">
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Zonder inruil-verplichting</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Snelle uitbetaling</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Geen gedoe met Marktplaats</li>
          </ul>
          <div class="mt-6 inline-flex items-center gap-2 text-emerald-700 font-semibold">Start verkoop via WhatsApp →</div>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- Accepted models -->
<section class="pb-16 md:pb-24">
  <div class="container-x">
    <div class="card p-6 md:p-10">
      <div class="flex items-start justify-between flex-wrap gap-4 mb-6">
        <div>
          <span class="chip mb-3">Welke toestellen?</span>
          <h2 class="text-2xl md:text-3xl font-black tracking-tight">We kopen deze modellen op</h2>
        </div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-100 border border-slate-200 text-xs font-medium text-slate-600">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          Andere modellen helaas niet
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="rounded-2xl border border-slate-200 p-6 bg-slate-50/60">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-white border border-slate-200 flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/></svg>
            </div>
            <h3 class="text-lg font-bold">iPhone</h3>
          </div>
          <ul class="space-y-2">
            {%- assign iphones_models = 'iPhone 13 · 13 mini · 13 Pro · 13 Pro Max,iPhone 14 · 14 Plus · 14 Pro · 14 Pro Max,iPhone 15 · 15 Plus · 15 Pro · 15 Pro Max,iPhone 16 · 16 Plus · 16 Pro · 16 Pro Max' | split: ',' -%}
            {% for m in iphones_models %}
              <li class="flex items-center gap-2 text-sm text-slate-700">
                <svg class="w-4 h-4 text-emerald-600 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span>{{ m }}</span>
              </li>
            {% endfor %}
          </ul>
        </div>

        <div class="rounded-2xl border border-slate-200 p-6 bg-slate-50/60">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-white border border-slate-200 flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/></svg>
            </div>
            <h3 class="text-lg font-bold">Samsung</h3>
          </div>
          <ul class="space-y-2">
            {%- assign sam_models = 'Galaxy S23 · S23+ · S23 Ultra,Galaxy S24 · S24+ · S24 Ultra,Galaxy S25 · S25+ · S25 Ultra' | split: ',' -%}
            {% for m in sam_models %}
              <li class="flex items-center gap-2 text-sm text-slate-700">
                <svg class="w-4 h-4 text-emerald-600 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span>{{ m }}</span>
              </li>
            {% endfor %}
          </ul>
        </div>
      </div>

      <p class="mt-6 text-xs text-slate-500 text-center">
        <strong>iPhone:</strong> vanaf iPhone 13-serie · <strong>Samsung:</strong> vanaf Galaxy S23-serie · Werkend of met defect — stuur foto's mee voor een eerlijk bod.
      </p>
    </div>
  </div>
</section>

<!-- How it works -->
<section class="section-pad bg-slate-50">
  <div class="container-x">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <span class="chip mb-3">Zo werkt het</span>
      <h2 class="text-3xl md:text-5xl font-black tracking-tight">In 3 stappen <span class="gradient-text">verkocht</span></h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {%- assign steps = '1|Chat op WhatsApp|Stuur ons merk, model, kleur en staat van je telefoon.,2|Ontvang je bod|We doen binnen korte tijd een eerlijk, marktconform bod.,3|Deal & afhandelen|Akkoord? We spreken af voor overhandiging en betaling.' | split: ',' -%}
      {% for s in steps %}
        {%- assign parts = s | split: '|' -%}
        <div class="card p-8 relative overflow-hidden">
          <div class="text-6xl font-black text-slate-100 absolute -top-2 right-4 select-none">{{ parts[0] }}</div>
          <div class="relative">
            <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-emerald-500 to-emerald-600 text-white flex items-center justify-center mb-4 shadow-lg shadow-emerald-600/30">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-2">{{ parts[1] }}</h3>
            <p class="text-slate-600 text-sm">{{ parts[2] }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Perks -->
<section class="section-pad">
  <div class="container-x">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      {%- assign perks = 'Snelle reactie|Geen wachtrij persoonlijk contact,Eerlijke prijs|Transparant en marktconform,Veilig & simpel|Geen gedoe met formulieren,Apple & Samsung|Werkend of met defect' | split: ',' -%}
      {% for p in perks %}
        {%- assign parts = p | split: '|' -%}
        <div class="card p-6">
          <div class="w-10 h-10 rounded-xl bg-brand-100 text-brand-700 flex items-center justify-center mb-3">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div class="font-bold">{{ parts[0] }}</div>
          <div class="text-sm text-slate-600 mt-1">{{ parts[1] }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Verkopen content",
  "settings": [],
  "presets": [{ "name": "Verkopen content" }]
}
{% endschema %}
