{%- comment -%}
  Pixel product card — wraps itself in the snap-start slider slot.
  Usage:
    {% render 'product-card',
       slug: 'iphone-13', name: 'iPhone 13', brand: 'Apple',
       storage: '128GB', color: 'Blauw', battery: 92,
       price: 249, original: 729, rating: 4.7, sold: false %}
{%- endcomment -%}
{%- assign discount = original | minus: price | times: 100 | divided_by: original -%}
{%- assign saving = original | minus: price -%}
{%- assign image = slug | prepend: 'p-' | append: '-01.jpg' | asset_url -%}

<div class="snap-start flex-shrink-0 w-[70%] sm:w-[45%] md:w-[33%] lg:w-[24%]">
  <a href="/pages/telefoon?p={{ slug }}" class="group card overflow-hidden block relative">
    <div class="relative aspect-square bg-gradient-to-br from-slate-50 to-slate-100 overflow-hidden">
      <img
        src="{{ image }}"
        alt="{{ name }}"
        loading="lazy"
        class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-500 {% if sold %}grayscale opacity-70{% endif %}"
      />

      {% unless sold %}
        {% if discount > 0 %}
          <span class="absolute top-3 right-3 text-xs font-bold px-2.5 py-1 rounded-full bg-rose-600 text-white z-10">
            -{{ discount }}%
          </span>
        {% endif %}
      {% endunless %}

      {% unless sold %}
        <button type="button" onclick="event.preventDefault();" class="absolute bottom-3 right-3 w-9 h-9 rounded-full bg-white/90 backdrop-blur flex items-center justify-center shadow-sm hover:bg-white hover:text-rose-600 transition" aria-label="Favoriet">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </button>
      {% endunless %}

      {% if sold %}
        <div class="absolute inset-0 bg-slate-900/20 pointer-events-none"></div>
        <div class="absolute inset-0 overflow-hidden pointer-events-none">
          <div class="absolute top-8 -right-14 w-[180%] rotate-[-20deg] bg-gradient-to-r from-rose-600 to-red-600 text-white text-center py-2 shadow-lg ring-1 ring-white/30">
            <span class="text-sm md:text-base font-black tracking-[0.15em] uppercase drop-shadow">Verkocht</span>
          </div>
        </div>
      {% endif %}
    </div>

    <div class="p-5">
      <div class="flex items-center justify-between gap-2 mb-1">
        <h3 class="font-semibold text-slate-900 group-hover:text-brand-700 transition">{{ name }}</h3>
        <div class="flex items-center gap-0.5 text-xs text-slate-500 flex-shrink-0">
          <svg class="w-3.5 h-3.5 fill-amber-400 text-amber-400" viewBox="0 0 24 24"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
          <span class="font-medium">{{ rating }}</span>
        </div>
      </div>
      <p class="text-sm text-slate-500">{{ storage }} &middot; {{ color }}</p>
      <div class="mt-2 flex items-center gap-1.5 text-xs text-slate-500">
        <svg class="w-3.5 h-3.5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="6" width="18" height="12" rx="2"/><line x1="23" y1="13" x2="23" y2="11"/></svg>
        <span>{{ battery }}% batterij</span>
      </div>
      <div class="mt-4 flex items-end justify-between">
        <div>
          <div class="text-xl font-black {% if sold %}text-slate-400 line-through{% else %}gradient-text{% endif %}">&euro;{{ price }}</div>
          <div class="text-xs text-slate-400 line-through">&euro;{{ original }}</div>
        </div>
        {% if sold %}
          <span class="text-[11px] font-semibold text-slate-600 bg-slate-100 border border-slate-200 px-2 py-1 rounded-full">Niet op voorraad</span>
        {% else %}
          <span class="text-[11px] font-semibold text-brand-700 bg-brand-50 border border-brand-100 px-2 py-1 rounded-full">Bespaar &euro;{{ saving }}</span>
        {% endif %}
      </div>
    </div>
  </a>
</div>
