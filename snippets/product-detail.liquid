{%- comment -%}
  Renders the full product-detail page for a single product.
  Wraps in [data-product-page="{slug}"] so client-side JS picks the matching one.
  Usage: {% render 'product-detail', slug: 'iphone-13', name: '...', brand: '...', ... %}
{%- endcomment -%}
{%- assign discount = original | minus: price | times: 100 | divided_by: original -%}
{%- assign saving = original | minus: price -%}
{%- assign wa_msg = 'Hoi Pixel! Ik wil graag de ' | append: name | append: ' (' | append: storage | append: ' - ' | append: color | append: ') bestellen voor EUR ' | append: price | append: '. Kunnen jullie mij helpen?' -%}
{%- assign wa_msg_enc = wa_msg | url_encode -%}
{%- assign wa_href = 'https://wa.me/31624978746?text=' | append: wa_msg_enc -%}
{%- capture color_css -%}{% render 'color-swatch', name: color %}{%- endcapture -%}

<div data-product-page="{{ slug }}" style="display: none;">
  <div class="container-x pt-6">
    <div class="flex items-center gap-2 text-xs text-slate-500">
      <a href="/" class="hover:text-brand-700">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/pages/telefoons" class="hover:text-brand-700">Telefoons</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      <span class="text-slate-900">{{ name }}</span>
    </div>
  </div>

  <section class="container-x py-10" x-data="{ active: 0 }">
    <div class="grid lg:grid-cols-2 gap-12">
      <div>
        <div class="card aspect-square overflow-hidden bg-gradient-to-br from-slate-50 to-slate-100 relative">
          {%- for i in (1..6) -%}
            {%- assign n = '0' | append: i -%}
            {%- assign src = slug | prepend: 'p-' | append: '-' | append: n | append: '.jpg' | asset_url -%}
            <img x-show="active === {{ forloop.index0 }}" src="{{ src }}" alt="{{ name }}" class="w-full h-full object-contain p-8 {% if sold %}grayscale opacity-70{% endif %}">
          {%- endfor -%}

          {% unless sold %}
            {% if discount > 0 %}
              <span class="absolute top-4 right-4 text-sm font-bold px-3 py-1.5 rounded-full bg-rose-600 text-white">-{{ discount }}%</span>
            {% endif %}
          {% endunless %}

          {% if sold %}
            <div class="absolute inset-0 bg-slate-900/15 pointer-events-none"></div>
            <div class="absolute inset-0 overflow-hidden pointer-events-none">
              <div class="absolute top-12 -right-20 w-[180%] rotate-[-20deg] bg-gradient-to-r from-rose-600 to-red-600 text-white text-center py-3 shadow-xl ring-1 ring-white/30">
                <span class="text-xl md:text-2xl font-black tracking-[0.2em] uppercase drop-shadow">Verkocht</span>
              </div>
            </div>
          {% endif %}
        </div>

        <div class="mt-4 grid grid-cols-6 gap-2 sm:gap-3">
          {%- for i in (1..6) -%}
            {%- assign n = '0' | append: i -%}
            {%- assign src = slug | prepend: 'p-' | append: '-' | append: n | append: '.jpg' | asset_url -%}
            <button type="button" @click="active = {{ forloop.index0 }}" :class="active === {{ forloop.index0 }} ? 'border-brand-500' : 'border-transparent hover:border-slate-300'" class="aspect-square rounded-2xl overflow-hidden border-2 transition bg-slate-50">
              <img src="{{ src }}" alt="" class="w-full h-full object-contain p-2">
            </button>
          {%- endfor -%}
        </div>
      </div>

      <div>
        <div class="flex items-center gap-3 text-sm mb-3">
          <span class="text-slate-500">{{ brand }}</span>
          <span class="text-slate-300">&middot;</span>
          <div class="flex items-center gap-1">
            <svg class="w-4 h-4 fill-amber-400 text-amber-400" viewBox="0 0 24 24"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            <span class="font-semibold">{{ rating }}</span>
            <span class="text-slate-500">({{ reviews }} reviews)</span>
          </div>
        </div>
        <h1 class="text-3xl md:text-4xl font-black tracking-tight">{{ name }}</h1>
        <p class="mt-3 text-slate-600">{{ description }}</p>

        <div class="mt-6 flex items-end gap-3">
          <div class="text-4xl font-black gradient-text">&euro;{{ price }}</div>
          <div class="text-slate-400 line-through mb-1">&euro;{{ original }}</div>
          <span class="ml-2 mb-1 text-sm font-semibold text-emerald-700 bg-emerald-50 border border-emerald-100 px-2 py-1 rounded-full">Bespaar &euro;{{ saving }}</span>
        </div>
        <p class="mt-1 text-xs text-slate-500">Bestel direct via WhatsApp &middot; Persoonlijke service</p>

        <div class="mt-6 flex items-center gap-2 text-sm">
          <svg class="w-4 h-4 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="6" width="18" height="12" rx="2"/></svg>
          <span class="font-medium">{{ battery }}% batterij</span>
          <span class="text-slate-400">&middot;</span>
          <span class="text-slate-600">Getest en goedgekeurd</span>
        </div>

        <div class="mt-8 flex flex-wrap gap-2">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-slate-200 bg-slate-50 text-sm font-medium">
            <span class="w-3 h-3 rounded-full border border-slate-300" style="background: {{ color_css | strip }};"></span>
            {{ color }}
          </div>
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-slate-200 bg-slate-50 text-sm font-medium">{{ storage }}</div>
        </div>
        <p class="mt-2 text-xs text-slate-500">Uniek toestel &mdash; de foto's zijn van deze specifieke telefoon.</p>

        {% if sold %}
          <div class="mt-8 p-5 rounded-2xl bg-slate-100 border border-slate-200 text-center">
            <div class="text-sm font-semibold uppercase tracking-wide text-slate-500 mb-1">Niet op voorraad</div>
            <div class="text-lg font-bold text-slate-900">Dit toestel is verkocht</div>
          </div>
        {% else %}
          <div class="mt-8">
            <a href="{{ wa_href }}" target="_blank" rel="noopener noreferrer" class="btn-wa w-full">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              Bestel via WhatsApp
            </a>
          </div>
        {% endif %}

        <div class="mt-8 grid grid-cols-3 gap-3">
          <div class="flex flex-col items-center text-center p-4 rounded-2xl bg-slate-50">
            <svg class="w-5 h-5 text-brand-600 mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span class="text-xs font-medium">6 maanden garantie</span>
          </div>
          <div class="flex flex-col items-center text-center p-4 rounded-2xl bg-slate-50">
            <svg class="w-5 h-5 text-brand-600 mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span class="text-xs font-medium">Gratis verzending</span>
          </div>
          <div class="flex flex-col items-center text-center p-4 rounded-2xl bg-slate-50">
            <svg class="w-5 h-5 text-brand-600 mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span class="text-xs font-medium">72-punten check</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
