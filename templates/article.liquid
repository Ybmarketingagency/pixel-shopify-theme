<article class="container-x py-16 max-w-3xl">
  <h1 class="text-3xl md:text-5xl font-black tracking-tight mb-2">{{ article.title }}</h1>
  <p class="text-sm text-slate-500 mb-8">{{ article.published_at | date: '%d %B %Y' }} · {{ article.author }}</p>
  <div class="prose max-w-none text-slate-700">{{ article.content }}</div>
</article>
