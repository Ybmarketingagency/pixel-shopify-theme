<div class="container-x py-16">
  <h1 class="text-3xl md:text-5xl font-black tracking-tight mb-6">{{ blog.title }}</h1>
  {% for article in blog.articles %}
    <article class="card p-6 mb-4">
      <h2 class="text-xl font-bold"><a href="{{ article.url }}" class="hover:text-brand-700">{{ article.title }}</a></h2>
      <p class="text-sm text-slate-500 mt-1">{{ article.published_at | date: '%d %b %Y' }}</p>
      <p class="text-slate-700 mt-3">{{ article.excerpt | strip_html | truncate: 180 }}</p>
    </article>
  {% endfor %}
</div>
