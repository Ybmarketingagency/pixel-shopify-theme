<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-brand-50 to-cyan-50 p-6">
  <div class="max-w-md w-full text-center card p-10">
    <img src="{{ 'logo.png' | asset_url }}" alt="Pixel" class="h-12 mx-auto mb-6">
    <h1 class="text-3xl font-black tracking-tight">Binnenkort open</h1>
    <p class="mt-3 text-slate-600">{{ shop.password_message }}</p>
    {% form 'storefront_password' %}
      <input type="password" name="password" placeholder="Wachtwoord" class="input mt-6" required>
      <button type="submit" class="btn-primary mt-3 w-full">Toegang</button>
      {{ form.errors | default_errors }}
    {% endform %}
  </div>
</div>
